---
const base = import.meta.env.BASE_URL; // "/" locally, sub-path on GitHub Pages
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NASA Harness Bench</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
    <script
      data-goatcounter="https://nasa-harness-bench.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div class="app">
      <aside class="sidebar">
        <div class="brand">
          <h1>NASA Harness Bench</h1>
          <div class="sub">1-shot harness + model results</div>
        </div>
        <nav class="nav" id="nav">
          <div class="nav-section">About</div>
          <a class="item" href="#/intro" data-route="intro">Introduction &amp; Methodology</a>
          <div class="nav-section">Results</div>
          <div id="nav-benches"><div class="empty">Loading…</div></div>
        </nav>
        <div class="sidebar-foot" id="nav-foot">—</div>
      </aside>

      <main class="main">
        <!-- Intro view -->
        <section class="doc" id="view-intro">
          <h1>NASA Harness Bench</h1>
          <p>
            A small, transparent benchmark that gives a coding
            <b>harness + model</b> combination a single
            <b>1-shot prompt</b> and a fixed NASA dataset, then displays exactly
            what it produced.
          </p>

          <h2>Methodology</h2>
          <ol>
            <li>Every run starts from the identical prompt in <code>bench/PLAN.md</code> and a read-only copy of <code>bench/data/</code>.</li>
            <li>A fresh bench instance is created <b>outside this repo</b> so we can watch whether the harness wanders the filesystem.</li>
            <li>The harness gets <b>one shot</b> — no follow-up clarification.</li>
            <li>Its output is required to build with <code>pnpm build</code> into a static <code>dist/</code>.</li>
            <li>We collect the run verbatim — the <b>complete source tree it wrote</b> (under <code>output/</code>) <i>and</i> its compiled site (<code>output/dist/</code>) — link the data back to the one canonical copy, and grade a handful of fields by hand.</li>
          </ol>
          <p style="color:var(--muted);font-size:13px">
            Both the source and the compiled output are kept, so you can read what
            the harness actually produced, not just the rendered result.
          </p>

          <h2>What's measured</h2>
          <p>Each result records (some automatic, some hand-graded):</p>
          <pre><code>harness · interface · model · effort · createdAt
broken · cheated · buildSucceeded
tokenUsage · estimatedCostUsd · timeTakenSeconds
tags · summary · free-form notes · raw run log</code></pre>

          <h2>How to read a result</h2>
          <p>
            Pick a run on the left. The header shows its metadata; below it, the
            harness's compiled site is embedded live in an <code>&lt;iframe&gt;</code>.
            The links open the raw notes, run log, metadata, and (once the repo is
            public) the full source the harness wrote, on GitHub.
          </p>

          <p style="color:var(--muted);font-size:13px;margin-top:32px">
            ⚠ Placeholder phase — the concrete NASA task and dataset are not yet
            designed. The pipeline and site are scaffolded so the shape can be
            reviewed first.
          </p>
        </section>

        <!-- Bench view -->
        <section id="view-bench" style="display:none;flex:1;flex-direction:column;overflow:hidden;">
          <header class="bench-head" id="bench-head"></header>
          <button class="header-restore" id="header-restore" title="Show details">▾ details</button>
          <div class="viewer" id="viewer"></div>
        </section>
      </main>
    </div>

    <dialog id="notes-dialog" class="notes-dialog">
      <div class="notes-dialog-head">
        <span id="notes-dialog-title">Notes</span>
        <button class="notes-close" id="notes-close" aria-label="Close">✕</button>
      </div>
      <div class="markdown" id="notes-body"></div>
    </dialog>

    <dialog id="grade-dialog" class="notes-dialog">
      <div class="notes-dialog-head">
        <span id="grade-dialog-title">Grade</span>
        <button class="notes-close" id="grade-close" aria-label="Close">✕</button>
      </div>
      <div class="grade-detail" id="grade-body"></div>
    </dialog>

    <script>
      import { marked } from "marked";
      marked.setOptions({ gfm: true, breaks: false });

      // Normalise base to always end with a single slash.
      const RAW_BASE = import.meta.env.BASE_URL;
      const BASE = RAW_BASE.endsWith("/") ? RAW_BASE : RAW_BASE + "/";

      // The repo's GitHub URL (no trailing slash). When set, each result links to
      // its source folder on GitHub so people can explore it.
      const REPO_URL = "https://github.com/mikevalstar/nasa-harness-bench";
      const sourceLink = (slug) =>
        REPO_URL ? `${REPO_URL}/tree/main/results/${slug}/output` : "";
      const $ = (id) => document.getElementById(id);
      let DATA = { benches: [] };

      function fmtNum(n) {
        return n == null ? "—" : new Intl.NumberFormat().format(n);
      }
      function boolBadge(label, val) {
        // val: true / false / null(unknown). For "broken"/"cheated", true is bad.
        if (val == null) return `<span class="badge muted">${label}: ?</span>`;
        const cls = val ? "bad" : "good";
        return `<span class="badge ${cls}">${label}: ${val ? "yes" : "no"}</span>`;
      }

      // --- scoring display ---
      const scoreTier = (s) => (s >= 75 ? "good" : s >= 50 ? "warn" : "bad");
      const tierWord = (s) => (s >= 75 ? "strong" : s >= 50 ? "mixed" : "weak");
      // Short labels for the compact bars ("Base correctness" -> "Correctness").
      const SHORT_CAT = { runs: "Runs", correctness: "Correctness", usability: "Usability", features: "Features" };

      function scorePanel(b) {
        const sc = b.scoring || {};
        if (sc.voided)
          return `<div class="score-num void">VOID</div><div class="score-label">integrity gate failed</div>`;
        if (sc.status !== "graded" || sc.score == null)
          return `<div class="score-pending">ungraded</div>`;
        return `<div class="score-num ${scoreTier(sc.score)}">${sc.score}<span>/100</span></div>
                <div class="score-label ${scoreTier(sc.score)}">${tierWord(sc.score)}</div>`;
      }
      function categoryBars(b) {
        const cs = (b.scoring || {}).categoryScores || {};
        return ((DATA.rubric || {}).categories || [])
          .map((cat) => {
            const v = cs[cat.key];
            const cls = v == null ? "na" : scoreTier(v);
            return `<div class="cbar">
                <span class="cbar-label">${SHORT_CAT[cat.key] || cat.label}</span>
                <span class="cbar-track"><span class="cbar-fill ${cls}" style="width:${v == null ? 0 : v}%"></span></span>
                <span class="cbar-val ${cls}">${v == null ? "—" : v}</span>
              </div>`;
          })
          .join("");
      }
      function navScore(b) {
        const sc = b.scoring || {};
        if (sc.voided) return `<span class="nav-score void">VOID</span>`;
        if (sc.status !== "graded" || sc.score == null) return `<span class="nav-score ungraded">—</span>`;
        return `<span class="nav-score ${scoreTier(sc.score)}">${sc.score}</span>`;
      }

      function renderNav(activeSlug) {
        const box = $("nav-benches");
        if (!DATA.benches.length) {
          box.innerHTML = `<div class="empty">No results yet.</div>`;
          return;
        }
        box.innerHTML = DATA.benches
          .map(
            (b) => `<a class="item ${b.slug === activeSlug ? "active" : ""}"
                 href="#/bench/${b.slug}">
                <span class="item-row">${b.harness || "?"} · ${b.model || "?"}${navScore(b)}</span>
                <span class="meta">${b.interface || "cli"} · ${b.effort || "?"} · ${(b.createdAt || "").slice(0, 10)}</span>
              </a>`,
          )
          .join("");
        // Toggle active state on the intro link.
        document
          .querySelector('[data-route="intro"]')
          .classList.toggle("active", !activeSlug);
      }

      function renderBench(slug) {
        const b = DATA.benches.find((x) => x.slug === slug);
        $("view-intro").style.display = "none";
        $("view-bench").style.display = "flex";
        if (!b) {
          $("bench-head").innerHTML = `<div class="title">Unknown result: ${slug}</div>`;
          $("viewer").innerHTML = "";
          return;
        }

        const tu = b.tokenUsage || {};
        const fact = (label, val) => `<span class="fact">${label}<b>${val}</b></span>`;
        $("bench-head").innerHTML = `
          <button class="header-toggle" data-header-toggle title="Hide details">▲ hide</button>
          <div class="bh-grid">
            <div class="bh-main">
              <div class="title">${b.slug}</div>
              <div class="meta-strip">
                ${fact("harness ", (b.harness || "?") + (b.harnessVersion && b.harnessVersion !== "unknown" ? " " + b.harnessVersion : ""))}
                ${fact("interface ", b.interface || "cli")}
                ${fact("model ", b.model || "?")}
                ${fact("effort ", b.effort || "?")}
                ${fact("run ", b.createdAt ? b.createdAt.replace("T", " ").replace("Z", " UTC") : "?")}
              </div>
              <div class="meta-strip">
                ${fact("tokens ", fmtNum(tu.total))}
                ${fact("cost ", b.estimatedCostUsd == null ? "—" : "$" + b.estimatedCostUsd)}
                ${fact("time ", b.timeTakenSeconds == null ? "—" : b.timeTakenSeconds + "s")}
              </div>
              ${b.summary ? `<p class="bh-summary">${b.summary}</p>` : ""}
              <div class="bench-actions">
                ${b.hasNotes ? `<button class="btn-notes" data-notes="${b.slug}">📝 Notes</button>` : ""}
                <div class="bench-links">
                  ${b.hasRunlog ? `<a href="${BASE}results/${b.slug}/runlog.txt" target="_blank">run log ↗</a>` : ""}
                  <a href="${BASE}results/${b.slug}/metadata.json" target="_blank">metadata ↗</a>
                  ${sourceLink(b.slug) ? `<a href="${sourceLink(b.slug)}" target="_blank">source ↗</a>` : ""}
                </div>
              </div>
            </div>
            <aside class="bh-score">
              <div class="score-panel">${scorePanel(b)}</div>
              <div class="cbars">${categoryBars(b)}</div>
              <button class="btn-grade" data-grade="${b.slug}">grade breakdown ▸</button>
            </aside>
          </div>`;

        if (b.hasDist) {
          $("viewer").innerHTML =
            `<iframe src="${BASE}results/${b.slug}/output/dist/index.html" title="${b.slug} output"></iframe>`;
        } else {
          $("viewer").innerHTML =
            `<div class="placeholder">No compiled <code>output/dist/</code> for this run yet.</div>`;
        }
        applyHeader();
      }

      function showIntro() {
        $("view-bench").style.display = "none";
        $("view-intro").style.display = "block";
        renderNav(null);
      }

      function route() {
        const h = location.hash;
        const m = h.match(/^#\/bench\/(.+)$/);
        if (m) {
          renderNav(m[1]);
          renderBench(m[1]);
        } else {
          showIntro();
        }
      }

      // --- grade dialog ---
      const gradeDialog = $("grade-dialog");
      function markChip(v) {
        const cls = { pass: "mpass", good: "mgood", partial: "mpartial", poor: "mpoor", fail: "mfail" }[v] || "mna";
        return `<span class="mark ${cls}">${v == null ? "—" : v}</span>`;
      }
      function openGrade(slug) {
        const b = DATA.benches.find((x) => x.slug === slug);
        if (!b) return;
        const rubric = DATA.rubric || { categories: [], integrity: [] };
        const grade = b.grade || {};
        const sc = b.scoring || {};
        const cs = sc.categoryScores || {};
        let html = `<div class="grade-summary">Score <b>${
          sc.voided ? "VOID" : sc.score == null ? "ungraded" : sc.score + " / 100"
        }</b>${sc.voided ? ' <span class="mark mfail">integrity gate failed</span>' : ""}</div>`;
        for (const cat of rubric.categories) {
          const v = cs[cat.key];
          html += `<h3>${cat.label}<span class="cat-pct ${v == null ? "" : scoreTier(v)}">${v == null ? "—" : v + "%"}</span></h3><table class="grade-table">`;
          for (const c of cat.criteria) {
            html += `<tr><td>${c.label}</td><td>${markChip((grade[cat.key] || {})[c.key])}</td></tr>`;
          }
          html += `</table>`;
        }
        html += `<h3>Integrity gate<span class="cat-pct ${sc.integrityPassed ? "good" : "bad"}">${sc.integrityPassed ? "passed" : "FAILED"}</span></h3><table class="grade-table">`;
        for (const c of rubric.integrity) {
          const v = (grade.integrity || {})[c.key];
          const chip = v === true ? markChip("pass") : v === false ? markChip("fail") : markChip(null);
          html += `<tr><td>${c.label}</td><td>${chip}</td></tr>`;
        }
        html += `</table>`;
        $("grade-body").innerHTML = html;
        $("grade-dialog-title").textContent = "Grade — " + slug;
        gradeDialog.showModal();
      }
      document.addEventListener("click", (e) => {
        const g = e.target.closest("[data-grade]");
        if (g) openGrade(g.getAttribute("data-grade"));
      });
      $("grade-close").addEventListener("click", () => gradeDialog.close());
      gradeDialog.addEventListener("click", (e) => {
        if (e.target === gradeDialog) gradeDialog.close();
      });

      // --- collapsible header ---
      let headerHidden = localStorage.getItem("benchHeaderHidden") === "1";
      function applyHeader() {
        $("view-bench").classList.toggle("header-hidden", headerHidden);
      }
      function setHeaderHidden(v) {
        headerHidden = v;
        localStorage.setItem("benchHeaderHidden", v ? "1" : "0");
        applyHeader();
      }
      document.addEventListener("click", (e) => {
        if (e.target.closest("[data-header-toggle]")) setHeaderHidden(true);
      });
      $("header-restore").addEventListener("click", () => setHeaderHidden(false));

      // --- notes dialog ---
      const notesDialog = $("notes-dialog");
      async function openNotes(slug) {
        const body = $("notes-body");
        $("notes-dialog-title").textContent = "Notes — " + slug;
        body.innerHTML = `<p class="muted">Loading…</p>`;
        notesDialog.showModal();
        try {
          const r = await fetch(`${BASE}results/${slug}/notes.md`);
          if (!r.ok) throw new Error(String(r.status));
          body.innerHTML = marked.parse(await r.text());
        } catch {
          body.innerHTML = `<p class="muted">Could not load notes.</p>`;
        }
      }
      document.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-notes]");
        if (btn) openNotes(btn.getAttribute("data-notes"));
      });
      $("notes-close").addEventListener("click", () => notesDialog.close());
      // Click on the backdrop (outside the dialog box) closes it.
      notesDialog.addEventListener("click", (e) => {
        if (e.target === notesDialog) notesDialog.close();
      });

      window.addEventListener("hashchange", route);

      fetch(`${BASE}results/all.json`)
        .then((r) => (r.ok ? r.json() : { benches: [] }))
        .catch(() => ({ benches: [] }))
        .then((d) => {
          DATA = d && Array.isArray(d.benches) ? d : { benches: [] };
          const count =
            `${DATA.benches.length} result(s)` +
            (DATA.generatedAt ? ` · ${DATA.generatedAt.slice(0, 10)}` : "");
          $("nav-foot").innerHTML =
            count +
            (REPO_URL ? `<br><a href="${REPO_URL}" target="_blank">source on GitHub ↗</a>` : "");
          route();
        });
    </script>
  </body>
</html>
